{
  "name": "@cyberdynecorp/excalidraw-editor",
  "version": "0.1.0",
  "description": "The pure editor state machine — tools, selection, transform, undo — ported from ExcalidrawEditor.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@cyberdynecorp/excalidraw-geometry": "workspace:*",
    "@cyberdynecorp/excalidraw-math": "workspace:*",
    "@cyberdynecorp/excalidraw-model": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "license": "MIT",
  "author": "Cyberdyne Corp AI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardoaraujosantos/excalidraw-swift.git",
    "directory": "web/packages/editor"
  },
  "homepage": "https://github.com/leonardoaraujosantos/excalidraw-swift#readme",
  "module": "./dist/index.js",
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
