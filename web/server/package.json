{
  "name": "@xs/server",
  "version": "0.0.0",
  "description": "WebSocket relay server for collaboration — rooms, presence, and version-reconciled scene sync.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
